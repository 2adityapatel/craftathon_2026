# .env (NEVER commit the actual .env file, this is an example template)

# 1. Server Configuration
HOST=0.0.0.0
PORT=8000

# 2. Database
# Using PostgreSQL locally. For Docker, it might look like: postgresql://postgres:postgres@localhost:5432/pocso
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pocso

# 3. Cryptography (RSA Keys for End-to-End Encryption)
# Run `python backend/scripts/generate_keys.py` to generate these locally.
RSA_PRIVATE_KEY_PATH=keys/private.pem
RSA_PUBLIC_KEY_PATH=keys/public.pem

# 4. Storage & AI (Get these from respective platforms)
# Get Pinata keys (for IPFS): https://app.pinata.cloud/developers/api-keys
PINATA_API_KEY=pk_...
PINATA_SECRET_KEY=sk_...
# Get HuggingFace token: https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=hf_...

# 5. Blockchain
# Wallet private key for Relayer. Create a fresh MetaMask wallet and copy private key.
SYSTEM_WALLET_PRIVATE_KEY=0x...
# After deploying the smart contract on Polygon Amoy testnet, paste the address here.
CONTRACT_ADDRESS=0x...

# 6. Admin Panel credentials (Basic implementation for hackathon)
ADMIN_USERNAME=admin
# bcrypt hash for password "admin": $2b$12$e/aow/8yGgTclEaE8Ym3.O7WbHkUjZc3hC2F3MInO2W0.A3vQG0/S
ADMIN_PASSWORD_HASH=$2b$12$e/aow/8yGgTclEaE8Ym3.O7WbHkUjZc3hC2F3MInO2W0.A3vQG0/S

# 7. Security constraints
RATE_LIMIT=5/minute
